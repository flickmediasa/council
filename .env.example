# OpenRouter — required. Used by both the UI (free models only) and the
# programmatic deliberate() / CLI path (free by default, paid opt-in).
OPENROUTER_API_KEY=

# Paid-tier opt-in for the programmatic path. Default: disabled.
# When "true", `resolveByTier({ allowPaid: true })` may return paid slugs
# (e.g. anthropic/claude-opus-4, openai/o3). Existing UI is unaffected and
# remains free-tier only. Double-gated to make accidental paid use impossible.
OPENROUTER_ALLOW_PAID=false

# ElevenLabs — optional. Voice output disables cleanly if empty.
ELEVENLABS_API_KEY=

# App branding (client-safe).
NEXT_PUBLIC_APP_NAME=Council
